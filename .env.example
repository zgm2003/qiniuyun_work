AI_PROVIDER=openai-compatible
OPENAI_COMPATIBLE_BASE_URL=https://api.openai.com/v1
OPENAI_COMPATIBLE_MODEL=gpt-5.5
OPENAI_COMPATIBLE_GENERATION_API=responses
# Production: set this on the server or hosting platform, never in client code.
# OPENAI_COMPATIBLE_API_KEY=your_api_key

MYSQL_DSN=mysql://app_user:app_password@127.0.0.1:3306/qiniuyun
MYSQL_CONNECTION_LIMIT=10

# Required when saving database-backed AI provider API keys.
# Generate with: node -e "console.log(require('node:crypto').randomBytes(32).toString('base64'))"
# AI_CONFIG_MASTER_KEY=base64_32_byte_key
